{
  "name": "page-event-hooks",
  "version": "0.0.1",
  "scripts": {
    "build": "env-cmd ng build --configuration production --project elements --output-hashing none --single-bundle",
    "watch": "env-cmd ng build --configuration production --project elements --output-hashing none --single-bundle --watch --plugin @sassoftware/vi-solution-extension-upload/src/upload-bundle.ngx-plugin",
    "create:solution-control": "env-cmd ng g @sassoftware/vi-solution-extension-angular-schematics:wc --project components",
    "add-mobile": "ng g @sassoftware/vi-solution-extension-angular-schematics:add-mobile",
    "build:mobile": "env-cmd ng build --configuration production --project mobile-elements --output-hashing none --single-bundle",
    "watch:mobile": "env-cmd ng build --configuration production --project mobile-elements --output-hashing none --single-bundle --watch --plugin @sassoftware/vi-solution-extension-upload/src/upload-bundle.ngx-plugin",
    "create:solution-control-mobile": "env-cmd ng g @sassoftware/vi-solution-extension-angular-schematics:mwc --project components"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.14",
    "@angular/common": "^19.2.14",
    "@angular/compiler": "^19.2.14",
    "@angular/core": "^19.2.14",
    "@angular/elements": "^19.2.14",
    "@angular/forms": "^19.2.14",
    "@angular/platform-browser": "^19.2.14",
    "@angular/platform-browser-dynamic": "^19.2.14",
    "@angular/router": "^19.2.14",
    "@sassoftware/mobile-investigator": "^4.2.2",
    "@sassoftware/vi-api": "latest",
    "ngx-build-plus": "^19.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.15",
    "@angular-devkit/core": "^19.2.15",
    "@angular/cli": "^19.2.15",
    "@angular/compiler-cli": "^19.2.14",
    "@sassoftware/vi-solution-extension-angular-schematics": "^1.1.0",
    "@sassoftware/vi-solution-extension-upload": "^0.5.0",
    "@types/jasmine": "~5.1.0",
    "env-cmd": "^10.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^19.2.2",
    "typescript": "~5.8.3"
  }
}
