{
  "name": "qr-update-17",
  "version": "0.0.0",
  "scripts": {
    "build": "env-cmd ng build --configuration production --project elements --output-hashing none --single-bundle",
    "watch": "env-cmd ng build --configuration production --project elements --output-hashing none --single-bundle --watch --plugin @sassoftware/vi-solution-extension-upload/src/upload-bundle.ngx-plugin",
    "create:solution-control": "env-cmd ng g @sassoftware/vi-solution-extension-angular-schematics:wc --project components",
    "add-mobile": "ng g @sassoftware/vi-solution-extension-angular-schematics:add-mobile",
    "build:mobile": "env-cmd ./node_modules/@angular/cli/bin/ng build --configuration production --project mobile-elements --output-hashing none --single-bundle",
    "watch:mobile": "env-cmd ./node_modules/@angular/cli/bin/ng build --configuration production --project mobile-elements --output-hashing none --single-bundle --watch --plugin @sassoftware/vi-solution-extension-upload/src/upload-bundle.ngx-plugin",
    "create:solution-control-mobile": "env-cmd ./node_modules/@angular/cli/bin/ng g @sassoftware/vi-solution-extension-angular-schematics:mwc --project components"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.3",
    "@angular/common": "^21.2.3",
    "@angular/compiler": "^21.2.3",
    "@angular/core": "^21.2.3",
    "@angular/elements": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/platform-browser": "^21.2.3",
    "@angular/platform-browser-dynamic": "^21.2.3",
    "@angular/router": "^21.2.3",
    "@progress/kendo-angular-barcodes": "^23.2.0",
    "@progress/kendo-angular-common": "^23.2.0",
    "@progress/kendo-drawing": "^1.24.0",
    "@progress/kendo-licensing": "^1.10.1",
    "@progress/kendo-ui": "^2026.1.212",
    "@sassoftware/mobile-investigator": "^4.4.2",
    "@sassoftware/vi-api": "1.54.1",
    "ngx-build-plus": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular-devkit/core": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.3",
    "@sassoftware/vi-solution-extension-angular-schematics": "^3.0.0",
    "@sassoftware/vi-solution-extension-upload": "^0.7.3",
    "@types/jasmine": "~5.1.0",
    "env-cmd": "^10.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.2.0",
    "typescript": "~5.9.3"
  }
}
